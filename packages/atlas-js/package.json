{
  "name": "@atlas-maps/js",
  "version": "0.1.0",
  "description": "Official JavaScript/TypeScript SDK for the Atlas maps platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["atlas", "maps", "geocoding", "routing", "africa", "maplibre"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
